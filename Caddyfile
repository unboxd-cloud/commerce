# Storefront (customer-facing)
{$PUBLIC_DOMAIN} {
    reverse_proxy mercur-storefront:3000
}

# Backend API + admin
api.{$PUBLIC_DOMAIN} {
    reverse_proxy mercur-backend:9000
}

# Medusa admin (same backend, routed for clarity)
admin.{$PUBLIC_DOMAIN} {
    reverse_proxy mercur-backend:9000
}

# Vendor panel
vendor.{$PUBLIC_DOMAIN} {
    reverse_proxy mercur-vendor:5173
}
