# Public domain (4 subdomains will be served)
#   {PUBLIC_DOMAIN}          -> storefront
#   api.{PUBLIC_DOMAIN}      -> backend API
#   admin.{PUBLIC_DOMAIN}    -> backend admin
#   vendor.{PUBLIC_DOMAIN}   -> vendor panel
PUBLIC_DOMAIN=marketplace.unboxd.cloud

# Postgres
POSTGRES_DB=mercur
POSTGRES_USER=mercur
POSTGRES_PASSWORD=__CHANGE_ME__

# Medusa secrets (generate with: openssl rand -hex 32)
JWT_SECRET=__CHANGE_ME__
COOKIE_SECRET=__CHANGE_ME__
